# Code-Swarm Environment Configuration

# ========== SECURITY (REQUIRED) ==========
# Production: Generate with `python -c "import secrets; print(secrets.token_urlsafe(64))"`
SECRET_KEY=your-strong-random-secret-key-here

# Comma-separated list of allowed origins (no spaces)
# Production: e.g., https://app.opensin.ai,https://docs.opensin.ai
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Environment: development | staging | production
ENVIRONMENT=development

# ========== PATH CONFIGURATION ==========
CODE_SWARM_BASE_DIR=.

# ========== DATABASE ==========
DATABASE_URL=postgresql://user:password@localhost:5432/code_swarm
REDIS_URL=redis://localhost:6379/0

# ========== MODELS & PROVIDERS ==========
# Primary model for SIN-Zeus
PRIMARY_MODEL=fireworks-ai/minimax-m2.7

# Vision model for look_at tool
VISION_MODEL=nvidia/nvidia/nemotron-3-nano-omni

# ========== PERFORMANCE ==========
MAX_WORKERS=10
RATE_LIMIT=1000/hour

# ========== MONITORING ==========
SENTRY_DSN=
PROMETHEUS_ENABLED=true

# ========== DEPLOYMENT ==========
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
